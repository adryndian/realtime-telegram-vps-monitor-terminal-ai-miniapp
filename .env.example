# Telegram VPS Monitor Mini App
DASHBOARD_PASSWORD=change-me
HOST=127.0.0.1
PORT=8787
REFRESH_SECONDS=5

# Telegram Mini App auth
# Set to your own Telegram numeric user ID.
ALLOWED_TG_USER_ID=123456789
# Optional direct Bot API alerts. Leave empty if using your own notifier.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Terminal security
# Empty = no PIN. Recommended: rely on Telegram initData auth + private tunnel/access layer.
TERMINAL_PIN=
TERMINAL_PASSWORD_FALLBACK=false

# Alert thresholds
ALERT_RAM_PCT=85
ALERT_DISK_PCT=85
ALERT_LOAD_PER_CORE=2.0
